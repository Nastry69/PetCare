# ================================================================
# PetCare — Variables d'environnement
# ================================================================
# ⚡ Démarrage rapide (dev / démo) :
#     docker compose up -d --build
#   → Aucun .env nécessaire, les valeurs par défaut sont intégrées.
#   → Les clés JWT sont générées automatiquement au premier démarrage.
#
# 🔒 Production : copiez ce fichier en ".env" et renseignez
#    toutes les valeurs. Ne committez JAMAIS le .env !
# ================================================================

# ── Application ─────────────────────────────────────────────────
APP_ENV=prod          # dev | prod
APP_SECRET=           # Chaîne aléatoire ≥ 32 caractères
                      # Génération : openssl rand -hex 32

# ── Base de données ──────────────────────────────────────────────
POSTGRES_DB=petcare
POSTGRES_USER=app
POSTGRES_PASSWORD=    # Mot de passe fort pour PostgreSQL

# ── JWT ─────────────────────────────────────────────────────────
JWT_PASSPHRASE=       # Passphrase pour les clés RSA JWT
                      # Génération : openssl rand -hex 32
                      # ℹ️  Les clés JWT sont générées automatiquement
                      #    au premier démarrage si elles sont absentes.

# ── Emails (Mailer) ──────────────────────────────────────────────
MAILER_DSN=smtp://mailer:1025          # Dev : Mailpit (http://localhost:8025)
# MAILER_DSN=smtp://user:pass@smtp.provider.com:587  # Prod : SendGrid / Brevo
MAILER_FROM_EMAIL=noreply@petcare.fr
MAILER_FROM_NAME=PetCare

# ── OAuth Google (optionnel) ────────────────────────────────────
# Créez un projet sur https://console.cloud.google.com
# → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Frontend ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api   # URL de l'API (visible côté navigateur)
FRONTEND_URL=http://localhost:3000       # URL du frontend (utilisée dans les emails)

# ── Ports d'accès (optionnel, valeurs par défaut) ────────────────
API_PORT=8000       # http://localhost:8000/api
FRONTEND_PORT=3000  # http://localhost:3000
